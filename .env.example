# BlendNBubbles environment variables (CRA exposes only REACT_APP_* to the browser).
# Copy to `.env.production` (or `.env`) and fill in real values, then rebuild.

# Apps Script web-app URL that appends spin-wheel results to a Google Sheet.
# Setup steps are documented at the bottom of src/SpinWheel.js. Leave empty
# to disable the audit log without breaking the wheel.
REACT_APP_SPIN_WEBHOOK_URL=
