rules_version = '2';

// BlendNBubbles Firestore rules.
//
// Deploy: Firebase Console -> Firestore Database -> Rules -> paste -> Publish.
// (Or `firebase deploy --only firestore:rules` where the CLI is set up.)
//
// The leaderboard is written directly by the public site, so these rules are
// the only server-side validation: they cap scores per game (real penalty
// play tops out at 18, so 40 is generous headroom; spoofed 101+ submissions
// get rejected even from dev tools), bound the PII field sizes, and forbid
// client edits or deletes of existing rows.
service cloud.firestore {
  match /databases/{database}/documents {

    match /leaderboard/{entry} {
      allow read: if true;

      allow create: if
        request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 40
        && request.resource.data.phone is string
        && request.resource.data.phone.size() <= 20
        && request.resource.data.week is string
        && request.resource.data.week.size() <= 12
        && (
          !('playerId' in request.resource.data)
          || (request.resource.data.playerId is string && request.resource.data.playerId.size() <= 36)
        )
        && request.resource.data.score is int
        && request.resource.data.score >= 0
        && (
          (request.resource.data.game == 'football' && request.resource.data.score <= 40)
          || (request.resource.data.game == 'bobacatcher' && request.resource.data.score <= 1000)
          || (!('game' in request.resource.data) && request.resource.data.score <= 1000)
        );

      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
